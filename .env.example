# RDOS environment variables
# Copy to .env and edit. Never commit real keys.

# === Local LLM (llama.cpp, OpenAI-compatible) ===
# Legacy aliases (still read by older scripts)
LOCAL_LLM_BASE_URL=http://10.10.10.12:8080
LOCAL_LLM_MODEL=qwythos-9b-q4
LOCAL_LLM_API_KEY=local-dev-key

# === Canonical RDOS local-model env vars (Batch 11+) ===
RDOS_LOCAL_CHAT_BASE_URL=http://10.10.10.12:8080
RDOS_LOCAL_CHAT_MODEL=qwythos-9b-q4
RDOS_LOCAL_EMBEDDING_BASE_URL=http://10.10.10.12:8081
RDOS_LOCAL_EMBEDDING_MODEL=bge-m3-q8_0
RDOS_LOCAL_EMBEDDING_DIM=1024
RDOS_LOCAL_MODEL_API_KEY=local-dev-key

# === Cloud (optional, used only for public / private_summary) ===
OPENAI_API_KEY=

# === Runtime toggles ===
RDOS_ENV=dev
RDOS_LOG_LEVEL=INFO
# Force fake embedding for tests/CI. Set to "false" once Batch 3 retrieval is stable.
RDOS_USE_FAKE_EMBEDDING=true
